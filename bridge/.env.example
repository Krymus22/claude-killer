# Bridge configuration — copy to .env and fill in.
# This .env is sourced by start-tunnel.sh.

# Required: shared secret between CLI and bridge server.
# Generate with: openssl rand -hex 32
BRIDGE_TOKEN=

# Optional: port the bridge server listens on (default 3000).
# BRIDGE_PORT=3000

# Optional: max requests per minute per IP (default 12, conservative).
# Increase only if your operator can keep up.
# BRIDGE_MAX_RPM=12

# Optional: how long the server waits for the operator to process a request
# before returning 504 (default 9 minutes — matches typical 10-min session
# window).
# BRIDGE_RESPONSE_TIMEOUT_MS=540000

# Optional: queue directory (default /tmp/ck-queue).
# Change if /tmp is wiped frequently on your system.
# BRIDGE_QUEUE_DIR=/tmp/ck-queue
